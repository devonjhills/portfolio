---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Experience from '../components/Experience.astro';
import ProjectsOptimized from '../components/ProjectsOptimized.astro';
import DiagonalSeparator from '../components/DiagonalSeparator.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="Devon Hills - Software Engineer"
  description="Software Engineer specializing in React, TypeScript, and modern web development. Building digital experiences that make a difference."
>
  <main>
    <Hero />
    <DiagonalSeparator direction="right" fromColor="white" toColor="gray-50" />
    <Services />
    <DiagonalSeparator direction="left" fromColor="gray-50" toColor="white" />
    <Experience />
    <DiagonalSeparator direction="right" fromColor="white" toColor="neutral-100" />
    <ProjectsOptimized />
    <DiagonalSeparator direction="left" fromColor="neutral-100" toColor="white" />
    <Contact />
  </main>
</Layout>
