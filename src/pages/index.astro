---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Experience from '../components/Experience.astro';
import ProjectsOptimized from '../components/ProjectsOptimized.astro';
import DiagonalSeparator from '../components/DiagonalSeparator.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="Devon Hills - Software Engineer"
  description="Software Engineer specializing in React, TypeScript, and modern web development. Building digital experiences that make a difference."
>
  <main>
    <!-- Hero Section - Pure white for maximum impact -->
    <Hero />
    <DiagonalSeparator
      direction="right"
      fromColor="section-light-1"
      toColor="section-light-2"
      variant="medium"
      height="h-20"
    />

    <!-- Services Section - First subtle background -->
    <Services />
    <DiagonalSeparator
      direction="left"
      fromColor="section-light-2"
      toColor="section-light-3"
      variant="subtle"
      height="h-16"
    />

    <!-- Experience Section - Second alternating background -->
    <Experience />
    <DiagonalSeparator
      direction="right"
      fromColor="section-light-3"
      toColor="section-light-4"
      variant="medium"
      height="h-18"
    />

    <!-- Projects Section - Third alternating background -->
    <ProjectsOptimized />
    <DiagonalSeparator
      direction="left"
      fromColor="section-light-4"
      toColor="section-light-1"
      variant="pronounced"
      height="h-16"
    />

    <!-- Contact Section - Back to pure white for clean finish -->
    <Contact />
  </main>
</Layout>
