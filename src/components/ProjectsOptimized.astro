---
// Optimized Projects section with compact headers
import { Icon } from 'astro-icon/components';
---

<section id="projects" class="py-20 bg-section-light-4 dark:bg-section-dark-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 animate-section-enter">
      <div
        class="inline-block mb-3 px-3 py-1 bg-neutral-100 dark:bg-neutral-900 border border-neutral-300 dark:border-neutral-700 font-terminal relative shadow-sm"
        style="border-radius: 0;"
      >
        <span
          class="text-xs font-terminal tracking-normal text-neutral-600 dark:text-neutral-400 glitch-effect"
          data-text="$ ls -la ~/projects">$ ls -la ~/projects</span
        >
        <div class="absolute -top-2 -right-2 w-2 h-2 bg-primary-500 rounded-full animate-pulse">
        </div>
      </div>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-heading font-semibold text-neutral-900 dark:text-neutral-50 mb-6 leading-tight tracking-tight"
      >
        Recent Work
      </h2>
    </div>

    <!-- Featured Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-12" id="projects-grid">
      <!-- Loading State -->
      <div
        class="bg-white dark:bg-neutral-900 overflow-hidden shadow-soft border border-neutral-200 dark:border-primary-500/30 terminal-card"
        style="border-radius: 0;"
      >
        <!-- Terminal Header Bar -->
        <div
          class="bg-neutral-100 dark:bg-neutral-800 px-4 py-2 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2"
        >
          <div class="flex space-x-1">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <div class="flex-1">
            <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400"
              >~/projects/loading...</span
            >
          </div>
        </div>
        <div class="p-4">
          <div class="animate-pulse space-y-4 font-terminal text-sm">
            <div class="mb-4 text-xs text-neutral-600 dark:text-neutral-400 font-mono space-y-1">
              <div class="flex items-center space-x-2">
                <span>drwxr-xr-x devon staff</span>
                <span class="ml-auto">loading...</span>
              </div>
              <div class="flex items-center justify-between">
                <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-primary-500"></div>
                <span>fetching projects...</span>
              </div>
            </div>
            <div class="h-3 bg-neutral-200 dark:bg-neutral-700 w-full" style="border-radius: 0;">
            </div>
            <div class="h-3 bg-neutral-200 dark:bg-neutral-700 w-2/3" style="border-radius: 0;">
            </div>
            <div class="flex gap-2 mt-4">
              <div class="h-4 bg-neutral-200 dark:bg-neutral-700 w-16" style="border-radius: 0;">
              </div>
              <div class="h-4 bg-neutral-200 dark:bg-neutral-700 w-20" style="border-radius: 0;">
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- View All Projects Link -->
    <div class="text-center">
      <a
        href="https://github.com/devonjhills"
        target="_blank"
        class="inline-flex items-center px-8 py-4 bg-neutral-100 dark:bg-neutral-800 text-primary-600 dark:text-primary-300 font-terminal border border-primary-500 dark:border-primary-400 hover:bg-primary-50 dark:hover:bg-neutral-700 transition-all duration-300 hover:scale-105"
        style="border-radius: 0;"
      >
        $ cd github.com/devonjhills
        <Icon name="simple-icons:github" class="ml-2 w-5 h-5" />
      </a>
    </div>
  </div>
</section>

<script>
  async function loadProjects() {
    try {
      const response = await fetch('/api/github-projects');
      if (!response.ok) throw new Error('Failed to fetch projects');

      const projects = await response.json();
      const grid = document.getElementById('projects-grid');

      if (!grid) return;

      // Clear loading state
      grid.innerHTML = '';

      // Show top 6 projects
      const featuredProjects = projects.slice(0, 6);

      featuredProjects.forEach((project: any, index: number) => {
        const projectCard = createProjectCard(project, index);
        grid.appendChild(projectCard);
      });
    } catch (error) {
      console.error('Error loading projects:', error);
      showFallbackProjects();
    }
  }

  function createProjectCard(project: any, index: number): HTMLDivElement {
    const card = document.createElement('div');
    card.className =
      'bg-white dark:bg-neutral-900 overflow-hidden shadow-soft hover:shadow-elevated transition-all duration-300 group border border-neutral-200 dark:border-primary-500/30 hover:-translate-y-2 hover:scale-[1.02] terminal-card';
    card.style.borderRadius = '0';
    card.style.animationDelay = `${index * 0.1}s`;
    card.style.animation = 'fade-in-up 0.6s ease-out both';

    // Format last updated
    const lastUpdated = new Date(project.updated_at).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });

    // Create terminal header with simple controls
    const terminalHeader = document.createElement('div');
    terminalHeader.className =
      'bg-neutral-100 dark:bg-neutral-800 px-4 py-2 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2';

    const controls = document.createElement('div');
    controls.className = 'flex space-x-1';
    controls.innerHTML = `
      <div class="w-3 h-3 rounded-full bg-red-500"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
      <div class="w-3 h-3 rounded-full bg-green-500"></div>
    `;

    const pathDisplay = document.createElement('div');
    pathDisplay.className = 'flex-1';
    pathDisplay.innerHTML = `<span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400">~/projects/${project.name}</span>`;

    const actionButtons = document.createElement('div');
    actionButtons.className = 'flex space-x-1';

    // GitHub button
    const githubBtn = document.createElement('a');
    githubBtn.href = project.html_url;
    githubBtn.target = '_blank';
    githubBtn.title = 'View on GitHub';
    githubBtn.className =
      'p-1 text-neutral-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors';
    githubBtn.innerHTML = '📁'; // Simple folder emoji for GitHub

    actionButtons.appendChild(githubBtn);

    // Homepage button if exists
    if (project.homepage) {
      const homeBtn = document.createElement('a');
      homeBtn.href = project.homepage;
      homeBtn.target = '_blank';
      homeBtn.title = 'Live Demo';
      homeBtn.className =
        'p-1 text-neutral-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors';
      homeBtn.innerHTML = '🔗'; // Simple link emoji for homepage
      actionButtons.appendChild(homeBtn);
    }

    terminalHeader.appendChild(controls);
    terminalHeader.appendChild(pathDisplay);
    terminalHeader.appendChild(actionButtons);

    // Create content area
    const content = document.createElement('div');
    content.className = 'p-4 font-terminal text-sm';

    // File listing header with better layout (2 lines)
    const fileHeader = document.createElement('div');
    fileHeader.className =
      'mb-4 text-xs text-neutral-600 dark:text-neutral-400 font-mono space-y-1';

    // Create clean file listing format on 2 lines
    const permissions = project.private ? 'drwx------' : 'drwxr-xr-x';
    const owner = 'devon';
    const group = 'staff';

    // Line 1: Permissions, owner, group, date
    let line1 = `<div class="flex items-center space-x-2">`;
    line1 += `<span>${permissions}</span>`;
    line1 += `<span>${owner}</span>`;
    line1 += `<span>${group}</span>`;
    line1 += `<span class="ml-auto">${lastUpdated}</span>`;
    line1 += `</div>`;

    // Line 2: Project name and stats
    let line2 = `<div class="flex items-center justify-between">`;
    line2 += `<span class="text-primary-600 dark:text-primary-400 font-semibold">${project.name}/</span>`;

    // Stats on the right if they exist
    if (project.stargazers_count > 0 || project.forks_count > 0) {
      line2 +=
        '<span class="text-neutral-500 dark:text-neutral-500 text-xs flex items-center space-x-2">';
      if (project.stargazers_count > 0) line2 += `<span>⭐ ${project.stargazers_count}</span>`;
      if (project.forks_count > 0) line2 += `<span>🍴 ${project.forks_count}</span>`;
      line2 += '</span>';
    }
    line2 += `</div>`;

    fileHeader.innerHTML = line1 + line2;

    // README section
    const readme = document.createElement('div');
    readme.className = 'mb-4 p-4 bg-neutral-50 dark:bg-neutral-800 border-l-2 border-primary-500';
    readme.innerHTML = `
      <div class="flex items-center space-x-2 mb-3">
        <span class="text-neutral-600 dark:text-neutral-400">📄</span>
        <span class="text-sm font-semibold text-neutral-700 dark:text-neutral-300">README.md</span>
      </div>
      <p class="text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed line-clamp-3">
        ${project.description || 'A modern web application showcasing best practices and clean code architecture with modern development workflows.'}
      </p>
    `;

    content.appendChild(fileHeader);
    content.appendChild(readme);

    // Topics as file tags
    if ((project.topics || []).length > 0) {
      const topicsDiv = document.createElement('div');
      topicsDiv.className = 'mt-3 pt-3 border-t border-neutral-200 dark:border-neutral-700';
      const tagsDiv = document.createElement('div');
      tagsDiv.className = 'flex flex-wrap gap-1';

      project.topics.slice(0, 3).forEach((topic: string) => {
        const tag = document.createElement('span');
        tag.className =
          'px-2 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-xs font-terminal border border-neutral-300 dark:border-neutral-600';
        tag.style.borderRadius = '0';
        tag.textContent = `#${topic}`;
        tagsDiv.appendChild(tag);
      });

      topicsDiv.appendChild(tagsDiv);
      content.appendChild(topicsDiv);
    }

    card.appendChild(terminalHeader);
    card.appendChild(content);

    return card;
  }

  function showFallbackProjects() {
    const grid = document.getElementById('projects-grid');
    if (!grid) return;

    const fallbackProjects = [
      {
        name: 'portfolio-website',
        description:
          'Modern portfolio website built with Astro, TypeScript, and Tailwind CSS featuring dynamic GitHub integration and responsive design.',
        languages: { TypeScript: 7000, CSS: 2000, JavaScript: 1000 },
        html_url: 'https://github.com/devonjhills',
        stargazers_count: 12,
        forks_count: 3,
        updated_at: '2024-12-01T00:00:00Z',
        topics: ['astro', 'typescript', 'tailwindcss', 'portfolio'],
      },
      {
        name: 'react-dashboard',
        description:
          'Healthcare data visualization dashboard built with React and modern UI libraries for real-time analytics.',
        languages: { JavaScript: 6500, CSS: 2500, HTML: 1500 },
        html_url: 'https://github.com/devonjhills',
        stargazers_count: 8,
        forks_count: 2,
        updated_at: '2024-11-15T00:00:00Z',
        topics: ['react', 'dashboard', 'healthcare', 'analytics'],
      },
    ];

    grid.innerHTML = '';
    fallbackProjects.forEach((project, index) => {
      const projectCard = createProjectCard(project, index);
      grid.appendChild(projectCard);
    });
  }

  // Load projects when the page loads
  document.addEventListener('DOMContentLoaded', loadProjects);
  document.addEventListener('astro:page-load', loadProjects);
</script>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
