---
// Optimized Projects section with compact headers
---

<section id="projects" class="py-20 bg-section-light-4 dark:bg-section-dark-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 animate-section-enter">
      <div
        class="inline-block mb-4 px-4 py-2 bg-neutral-100 dark:bg-neutral-900 border border-primary-500 dark:border-primary-400 font-terminal text-primary-700 dark:text-primary-300 relative shadow-sm"
        style="border-radius: 0;"
      >
        <span class="text-sm font-medium uppercase tracking-wide glitch-effect" data-text="$ ls ~/projects">$ ls ~/projects</span>
        <div class="absolute -top-2 -right-2 w-2 h-2 bg-primary-500 rounded-full animate-pulse"></div>
      </div>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-heading font-semibold text-neutral-900 dark:text-neutral-50 mb-6 leading-tight tracking-tight"
      >
        Selected Work
      </h2>
      <p
        class="text-lg sm:text-xl text-neutral-700 dark:text-neutral-300 max-w-3xl mx-auto leading-relaxed"
      >
        A showcase of recent projects demonstrating full-stack development, modern web technologies,
        and problem-solving approaches.
      </p>
    </div>

    <!-- Featured Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-12" id="projects-grid">
      <!-- Loading State -->
      <div
        class="bg-white dark:bg-neutral-900 overflow-hidden shadow-soft border border-neutral-200 dark:border-primary-500/30 terminal-card"
        style="border-radius: 0;"
      >
        <!-- Terminal Header Bar -->
        <div class="bg-neutral-100 dark:bg-neutral-800 px-4 py-2 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2">
          <div class="flex space-x-1">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <div class="flex-1">
            <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400">~/projects/loading...</span>
          </div>
        </div>
        <div class="p-4">
          <div class="animate-pulse space-y-4 font-terminal text-sm">
            <div class="flex items-center space-x-2 mb-3 text-xs text-neutral-600 dark:text-neutral-400">
              <span>drwxr-xr-x</span>
              <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-primary-500"></div>
            </div>
            <div class="h-3 bg-neutral-200 dark:bg-neutral-700 w-full" style="border-radius: 0;"></div>
            <div class="h-3 bg-neutral-200 dark:bg-neutral-700 w-2/3" style="border-radius: 0;"></div>
            <div class="flex gap-2 mt-4">
              <div class="h-4 bg-neutral-200 dark:bg-neutral-700 w-16" style="border-radius: 0;"></div>
              <div class="h-4 bg-neutral-200 dark:bg-neutral-700 w-20" style="border-radius: 0;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- View All Projects Link -->
    <div class="text-center">
      <a
        href="https://github.com/devonjhills"
        target="_blank"
        class="inline-flex items-center px-8 py-4 bg-neutral-900 dark:bg-neutral-800 text-primary-400 dark:text-primary-300 font-terminal border border-primary-500 dark:border-primary-400 hover:bg-primary-50 dark:hover:bg-neutral-700 transition-all duration-300 hover:scale-105"
        style="border-radius: 0;"
      >
        $ cd github.com/devonjhills
        <svg class="ml-2 w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Helper function to format repository names
  function formatRepoName(name: string): string {
    return name
      .split(/[-_]/)
      .map((word: string) => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' ')
      .replace(/([a-z])([A-Z])/g, '$1 $2')
      .trim();
  }

  async function loadProjects() {
    try {
      const response = await fetch('/api/github-projects');
      if (!response.ok) throw new Error('Failed to fetch projects');

      const projects = await response.json();
      const grid = document.getElementById('projects-grid');

      if (!grid) return;

      // Clear loading state
      grid.innerHTML = '';

      // Show top 6 projects
      const featuredProjects = projects.slice(0, 6);

      featuredProjects.forEach((project: any, index: number) => {
        const projectCard = createProjectCard(project, index);
        grid.appendChild(projectCard);
      });
    } catch (error) {
      console.error('Error loading projects:', error);
      showFallbackProjects();
    }
  }

  function createProjectCard(project: any, index: number): HTMLDivElement {
    const card = document.createElement('div');
    card.className =
      'bg-white dark:bg-neutral-900 overflow-hidden shadow-soft hover:shadow-elevated transition-all duration-300 group border border-neutral-200 dark:border-primary-500/30 hover:-translate-y-2 hover:scale-[1.02] terminal-card';
    card.style.borderRadius = '0';
    card.style.animationDelay = `${index * 0.1}s`;
    card.style.animation = 'fade-in-up 0.6s ease-out both';

    // Enhanced language colors
    const languageColors: Record<string, string> = {
      JavaScript: '#f1e05a',
      TypeScript: '#3178c6',
      Python: '#3572A5',
      HTML: '#e34c26',
      CSS: '#1572B6',
      React: '#61dafb',
      Vue: '#4FC08D',
      Java: '#b07219',
      Go: '#00ADD8',
      Rust: '#dea584',
      Swift: '#fa7343',
      Kotlin: '#7f52ff',
      Dart: '#0175c2',
      PHP: '#777bb4',
      Ruby: '#cc342d',
      'C++': '#f34b7d',
      'C#': '#239120',
      Shell: '#89e051',
    };

    const languages = project.languages || {};
    const languageEntries = Object.entries(languages);
    const totalBytes = languageEntries.reduce((sum, [, bytes]) => sum + (bytes as number), 0);
    const primaryLanguage = languageEntries[0]?.[0];
    const languageColor = languageColors[primaryLanguage as string] || '#6b7280';

    // Format project name
    const displayName = formatRepoName(project.name);

    // Create language breakdown bar
    const languageBar = languageEntries
      .slice(0, 5)
      .map(([lang, bytes]) => {
        const percentage = (((bytes as number) / totalBytes) * 100).toFixed(1);
        const color = languageColors[lang as string] || '#6b7280';
        return `<div class="h-full transition-all duration-300" style="width: ${percentage}%; background-color: ${color};" title="${lang}: ${percentage}%"></div>`;
      })
      .join('');

    // Format topics as tags
    const topicTags = (project.topics || [])
      .slice(0, 3)
      .map(
        (topic: string) =>
          `<span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-800 dark:text-neutral-200 text-xs rounded-full font-medium">${topic}</span>`
      )
      .join('');

    // Format last updated
    const lastUpdated = new Date(project.updated_at).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });

    card.innerHTML = `
      <!-- Terminal Header Bar -->
      <div class="bg-neutral-100 dark:bg-neutral-800 px-4 py-2 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2">
        <div class="flex space-x-1">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
        </div>
        <div class="flex-1">
          <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400">~/projects/${project.name}</span>
        </div>
        <div class="flex space-x-1">
          <a href="${project.html_url}" target="_blank" class="p-1 text-neutral-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors" title="View on GitHub">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          ${
            project.homepage
              ? `
            <a href="${project.homepage}" target="_blank" class="p-1 text-neutral-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors" title="Live Demo">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          `
              : ''
          }
        </div>
      </div>
      
      <!-- File Directory Content -->
      <div class="p-4 font-terminal text-sm">
        <!-- File Listing Header -->
        <div class="flex items-center space-x-2 mb-3 text-xs text-neutral-600 dark:text-neutral-400">
          <span>drwxr-xr-x</span>
          ${project.stargazers_count > 0 ? `<span>${project.stargazers_count} stars</span>` : ''}
          ${project.forks_count > 0 ? `<span>${project.forks_count} forks</span>` : ''}
          <span class="ml-auto">${lastUpdated}</span>
        </div>
        
        <!-- Project Description as README -->
        <div class="mb-4 p-4 bg-neutral-50 dark:bg-neutral-800 border-l-2 border-primary-500">
          <div class="flex items-center space-x-2 mb-3">
            <svg class="w-4 h-4 text-neutral-600 dark:text-neutral-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M4 3a2 2 0 100 4h12a2 2 0 100-4H4zM3 8a1 1 0 000 2v5a2 2 0 002 2h6a2 2 0 002-2v-5a1 1 0 000-2H3z"/>
            </svg>
            <span class="text-sm font-semibold text-neutral-700 dark:text-neutral-300">README.md</span>
          </div>
          <p class="text-neutral-700 dark:text-neutral-300 text-sm leading-relaxed line-clamp-3">
            ${project.description || 'A modern web application showcasing best practices and clean code architecture with modern development workflows.'}
          </p>
        </div>
        
        <!-- Topics as file tags -->
        ${
          (project.topics || []).length > 0
            ? `
          <div class="mt-3 pt-3 border-t border-neutral-200 dark:border-neutral-700">
            <div class="flex flex-wrap gap-1">
              ${(project.topics || [])
                .slice(0, 3)
                .map(
                  (topic: string) =>
                    `<span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-xs font-terminal border border-neutral-300 dark:border-neutral-600" style="border-radius: 0;">#${topic}</span>`
                )
                .join('')}
            </div>
          </div>
        `
            : ''
        }
      </div>
    `;

    return card;
  }

  function showFallbackProjects() {
    const grid = document.getElementById('projects-grid');
    if (!grid) return;

    const fallbackProjects = [
      {
        name: 'portfolio-website',
        description:
          'Modern portfolio website built with Astro, TypeScript, and Tailwind CSS featuring dynamic GitHub integration and responsive design.',
        languages: { TypeScript: 7000, CSS: 2000, JavaScript: 1000 },
        html_url: 'https://github.com/devonjhills',
        stargazers_count: 12,
        forks_count: 3,
        updated_at: '2024-12-01T00:00:00Z',
        topics: ['astro', 'typescript', 'tailwindcss', 'portfolio'],
      },
      {
        name: 'react-dashboard',
        description:
          'Healthcare data visualization dashboard built with React and modern UI libraries for real-time analytics.',
        languages: { JavaScript: 6500, CSS: 2500, HTML: 1500 },
        html_url: 'https://github.com/devonjhills',
        stargazers_count: 8,
        forks_count: 2,
        updated_at: '2024-11-15T00:00:00Z',
        topics: ['react', 'dashboard', 'healthcare', 'analytics'],
      },
    ];

    grid.innerHTML = '';
    fallbackProjects.forEach((project, index) => {
      const projectCard = createProjectCard(project, index);
      grid.appendChild(projectCard);
    });
  }

  // Load projects when the page loads
  document.addEventListener('DOMContentLoaded', loadProjects);
  document.addEventListener('astro:page-load', loadProjects);
</script>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
