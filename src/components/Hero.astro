---
import Button from './ui/Button.astro';
import { Icon } from 'astro-icon/components';
---

<section class="relative overflow-hidden bg-section-light-1 dark:bg-section-dark-1 pt-16">
  <!-- Hero Background Image -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-15 dark:opacity-20"
    style="background-image: url('/hero-bg.png');"
  >
  </div>
  <!-- Matrix-Inspired Enhanced Background Pattern -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-primary-50/10 via-transparent to-primary-100/8 dark:from-transparent dark:via-transparent dark:to-transparent"
  >
  </div>
  <div class="absolute inset-0 opacity-40 dark:opacity-30">
    <div
      class="absolute top-1/4 left-1/4 w-80 h-80 bg-gradient-to-br from-primary-400/15 to-primary-500/8 dark:from-green-400/20 dark:to-green-500/15 rounded-full blur-3xl animate-float"
    >
    </div>
    <div
      class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-gradient-to-tl from-primary-500/12 to-primary-600/6 dark:from-green-500/18 dark:to-green-400/12 rounded-full blur-3xl animate-float"
      style="animation-delay: -2s;"
    >
    </div>
    <div
      class="absolute top-1/2 right-1/3 w-64 h-64 bg-gradient-to-bl from-secondary-400/10 to-primary-300/8 dark:from-emerald-400/15 dark:to-green-300/10 rounded-full blur-2xl animate-float"
      style="animation-delay: -4s;"
    >
    </div>
    <div
      class="absolute top-3/4 left-1/3 w-72 h-72 bg-gradient-to-tr from-primary-200/8 to-accent-300/6 dark:from-lime-400/12 dark:to-green-400/8 rounded-full blur-2xl animate-float"
      style="animation-delay: -6s;"
    >
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    <div class="pt-16 pb-16 sm:pt-20 sm:pb-20 lg:pt-24 lg:pb-24">
      <!-- Main Content -->
      <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
        <!-- Text Content -->
        <div class="flex-1 text-center lg:text-left space-y-10">
          <!-- Avatar - Mobile Only -->
          <div class="lg:hidden flex justify-center mb-10">
            <img
              src="/avatar.png"
              alt="Devon Hills"
              class="w-36 h-36 rounded-full border-4 border-neutral-200 dark:border-neutral-700 shadow-soft"
            />
          </div>

          <!-- Main Headline -->
          <div class="space-y-8">
            <h1
              class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-heading font-semibold tracking-tight leading-[1.1]"
            >
              <span class="text-gray-900 dark:text-white">Building scalable web applications</span>
              <span
                class="text-primary-600 dark:text-primary-400 glitch-effect typewriter"
                data-text="that millions depend on."
                ><span id="typewriter-text"></span><span class="typewriter-cursor">|</span></span
              >
            </h1>

            <p
              class="max-w-2xl mx-auto lg:mx-0 text-lg sm:text-xl lg:text-2xl text-gray-700 dark:text-gray-200 leading-relaxed font-medium"
            >
              Full-stack engineer with 7+ years crafting mission-critical software. From healthcare
              platforms serving 10M+ users to defense systems requiring bulletproof reliability, I
              deliver production-grade solutions with modern React, TypeScript, and cloud
              architecture.
            </p>
          </div>

          <!-- CTA Buttons -->
          <div
            class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start items-stretch sm:items-center"
          >
            <Button
              href="#projects"
              variant="primary"
              size="lg"
              class="flex-1 sm:flex-none justify-center"
            >
              View My Work
              <Icon name="heroicons:chevron-right" class="ml-2 w-5 h-5" />
            </Button>

            <Button
              href="/Devon_Hills_Resume_2025_Newest.pdf"
              target="_blank"
              variant="outline"
              size="lg"
              download
              class="flex-1 sm:flex-none justify-center"
            >
              Download Resume
              <Icon name="heroicons:arrow-down-tray" class="ml-2 w-5 h-5" />
            </Button>
          </div>

          <!-- Professional Links -->
          <div class="flex justify-center lg:justify-start gap-6 pt-4">
            <a
              href="https://linkedin.com/in/devonjhills"
              target="_blank"
              class="text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
              aria-label="LinkedIn"
            >
              <Icon name="simple-icons:linkedin" class="w-6 h-6" />
            </a>

            <a
              href="https://github.com/devonjhills"
              target="_blank"
              class="text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
              aria-label="GitHub"
            >
              <Icon name="simple-icons:github" class="w-6 h-6" />
            </a>

            <a
              href="mailto:devonjhills@gmail.com"
              class="text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
              aria-label="Email"
            >
              <Icon name="heroicons:envelope" class="w-6 h-6" />
            </a>
          </div>
        </div>

        <!-- Avatar - Desktop -->
        <div class="hidden lg:block flex-shrink-0">
          <img
            src="/avatar.png"
            alt="Devon Hills"
            class="w-72 h-72 xl:w-80 xl:h-80 rounded-full border-4 border-neutral-200 dark:border-neutral-700 shadow-soft"
          />
        </div>
      </div>

      <!-- Subtitle -->
      <div class="mt-16 text-center">
        <p class="text-sm uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-2">
          Currently
        </p>
        <h2
          class="text-2xl sm:text-3xl font-heading font-semibold text-gray-900 dark:text-white leading-relaxed"
        >
          Architecting client solutions at
          <span class="text-primary-600 dark:text-primary-400">Livefront</span>
        </h2>
      </div>
    </div>
  </div>
</section>

<style>
  /* Animations for hero elements */
  h1 {
    animation: fade-in-up 0.8s ease-out;
  }

  p {
    animation: fade-in-up 0.8s ease-out 0.2s both;
  }

  .flex.flex-col {
    animation: fade-in-up 0.8s ease-out 0.4s both;
  }

  .grid {
    animation: fade-in 1s ease-out 0.6s both;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Typewriter cursor animation */
  .typewriter-cursor {
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    51%,
    100% {
      opacity: 0;
    }
  }
</style>

<script>
  function initTypewriter() {
    const text = 'that millions depend on.';
    const typewriterElement = document.getElementById('typewriter-text');
    const cursor = document.querySelector('.typewriter-cursor');

    if (!typewriterElement) return;

    let index = 0;

    function typeWriter() {
      if (index < text.length && typewriterElement) {
        typewriterElement.textContent += text.charAt(index);
        index++;
        setTimeout(typeWriter, 100); // Adjust speed here (milliseconds)
      } else {
        // Hide cursor after typing is complete
        setTimeout(() => {
          if (cursor && cursor instanceof HTMLElement) cursor.style.display = 'none';
        }, 1000);
      }
    }

    // Start typewriter effect after a small delay
    setTimeout(() => {
      typeWriter();
    }, 2000);
  }

  // Initialize on DOM ready
  document.addEventListener('DOMContentLoaded', initTypewriter);

  // Handle Astro page transitions
  document.addEventListener('astro:page-load', initTypewriter);
</script>
