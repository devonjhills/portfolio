---
export interface Props {
  title: string;
  directory?: string;
  icon?: string;
  description?: string;
  tags?: string[];
  tagType?: 'primary' | 'neutral';
  iconBg?: 'primary' | 'neutral';
  class?: string;
}

const {
  title,
  directory = '~/dev',
  description,
  tags = [],
  tagType = 'primary',
  iconBg = 'primary',
  class: className = '',
} = Astro.props;

const tagClasses =
  tagType === 'primary'
    ? 'bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900'
    : 'bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 border-neutral-300 dark:border-neutral-600 hover:bg-neutral-200 dark:hover:bg-neutral-700';

const iconBgClasses =
  iconBg === 'primary'
    ? 'bg-primary-100 dark:bg-primary-900'
    : 'bg-neutral-100 dark:bg-neutral-700';
---

<div
  class={`bg-white dark:bg-neutral-900 p-0 shadow-soft hover:shadow-elevated border border-neutral-200 dark:border-primary-500/30 transition-all duration-300 hover:-translate-y-2 hover:scale-[1.02] group relative overflow-hidden terminal-card ${className}`}
  style="border-radius: 0;"
>
  <!-- Terminal Header Bar -->
  <div
    class="bg-neutral-100 dark:bg-neutral-800 px-4 py-2 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2"
  >
    <div class="flex space-x-1">
      <div class="w-3 h-3 rounded-full bg-red-500"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
      <div class="w-3 h-3 rounded-full bg-green-500"></div>
    </div>
    <div class="flex-1">
      <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400">
        {directory}
      </span>
    </div>
  </div>

  <!-- Card Content -->
  <div class="p-8">
    <div class="flex items-start space-x-6">
      <div class="flex-shrink-0">
        <div
          class={`w-14 h-14 ${iconBgClasses} rounded-xl flex items-center justify-center shadow-soft group-hover:shadow-medium transition-all duration-300 group-hover:scale-105`}
        >
          <slot name="icon">
            <svg
              class="w-7 h-7 text-primary-600 dark:text-primary-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </slot>
        </div>
      </div>
      <div class="flex-1">
        <h3 class="text-xl font-heading font-medium text-gray-900 dark:text-white mb-3">
          {title}
        </h3>
        {description && <p class="text-gray-600 dark:text-gray-300 mb-4">{description}</p>}
        <slot name="content" />
        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map(tag => (
                <span
                  class={`px-3 py-1 text-sm font-terminal border transition-all duration-200 ${tagClasses}`}
                  style="border-radius: 0;"
                >
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</div>
