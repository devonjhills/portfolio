---
// Contact section inspired by Livefront's partnership approach
---

<section id="contact" class="py-24 bg-section-light-5 dark:bg-section-dark-5">
  <div class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-12">
    <!-- Section Header -->
    <div class="text-center mb-20 animate-section-enter">
      <div
        class="inline-block mb-4 px-4 py-2 bg-neutral-100 dark:bg-neutral-900 border border-primary-500 dark:border-primary-400 font-terminal text-primary-700 dark:text-primary-300 relative shadow-sm glitch-effect"
        style="border-radius: 0;"
        data-text="$ ssh devon@portfolio.dev"
      >
        <span class="text-sm font-medium uppercase tracking-wide">$ ssh devon@portfolio.dev</span>
        <div class="absolute -top-2 -right-2 w-2 h-2 bg-primary-500 rounded-full animate-pulse">
        </div>
      </div>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-heading font-semibold text-neutral-900 dark:text-neutral-50 leading-tight tracking-tight mb-6"
      >
        Let's build something remarkable.
      </h2>
      <p
        class="text-lg sm:text-xl text-neutral-700 dark:text-neutral-300 max-w-3xl mx-auto leading-relaxed"
      >
        I'm always interested in connecting with fellow developers, exploring new opportunities, and
        collaborating on projects that make a difference.
      </p>
    </div>

    <!-- Terminal-style Contact Grid -->
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <!-- Contact Terminal -->
        <div
          class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 shadow-soft terminal-card"
          style="border-radius: 0;"
        >
          <!-- Terminal Header -->
          <div
            class="bg-neutral-100 dark:bg-neutral-800 px-4 py-3 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2"
          >
            <div class="flex space-x-1">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
            </div>
            <div class="flex-1">
              <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400"
                >~/contact/methods</span
              >
            </div>
          </div>
          <!-- Terminal Content -->
          <div class="p-6 space-y-4 font-terminal text-sm">
            <div class="text-primary-600 dark:text-primary-400 mb-4">$ ls -la contact/</div>

            <!-- Email -->
            <a
              href="mailto:devonjhills@gmail.com"
              class="flex items-center space-x-3 p-3 hover:bg-primary-50 dark:hover:bg-primary-950 border border-transparent hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-200 group cursor-pointer"
              style="border-radius: 0;"
            >
              <div
                class="w-8 h-8 bg-primary-100 dark:bg-primary-900 flex items-center justify-center text-primary-600 dark:text-primary-400 group-hover:bg-primary-200 dark:group-hover:bg-primary-800 transition-colors"
              >
                <span class="font-bold">@</span>
              </div>
              <div class="flex-1">
                <div
                  class="text-neutral-900 dark:text-neutral-100 font-medium group-hover:text-primary-700 dark:group-hover:text-primary-300 transition-colors"
                >
                  email.sh
                </div>
                <div class="text-neutral-600 dark:text-neutral-400 text-xs">
                  devonjhills@gmail.com
                </div>
              </div>
              <div class="text-neutral-400 group-hover:text-primary-500 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path>
                </svg>
              </div>
            </a>

            <!-- LinkedIn -->
            <a
              href="https://linkedin.com/in/devonjhills"
              target="_blank"
              class="flex items-center space-x-3 p-3 hover:bg-primary-50 dark:hover:bg-primary-950 border border-transparent hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-200 group cursor-pointer"
              style="border-radius: 0;"
            >
              <div
                class="w-8 h-8 bg-primary-100 dark:bg-primary-900 flex items-center justify-center text-primary-600 dark:text-primary-400 group-hover:bg-primary-200 dark:group-hover:bg-primary-800 transition-colors"
              >
                <span class="font-bold text-xs">in</span>
              </div>
              <div class="flex-1">
                <div
                  class="text-neutral-900 dark:text-neutral-100 font-medium group-hover:text-primary-700 dark:group-hover:text-primary-300 transition-colors"
                >
                  linkedin.sh
                </div>
                <div class="text-neutral-600 dark:text-neutral-400 text-xs">/in/devonjhills</div>
              </div>
              <div class="text-neutral-400 group-hover:text-primary-500 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path>
                </svg>
              </div>
            </a>

            <!-- GitHub -->
            <a
              href="https://github.com/devonjhills"
              target="_blank"
              class="flex items-center space-x-3 p-3 hover:bg-primary-50 dark:hover:bg-primary-950 border border-transparent hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-200 group cursor-pointer"
              style="border-radius: 0;"
            >
              <div
                class="w-8 h-8 bg-primary-100 dark:bg-primary-900 flex items-center justify-center text-primary-600 dark:text-primary-400 group-hover:bg-primary-200 dark:group-hover:bg-primary-800 transition-colors"
              >
                <span class="font-bold text-xs">gh</span>
              </div>
              <div class="flex-1">
                <div
                  class="text-neutral-900 dark:text-neutral-100 font-medium group-hover:text-primary-700 dark:group-hover:text-primary-300 transition-colors"
                >
                  github.sh
                </div>
                <div class="text-neutral-600 dark:text-neutral-400 text-xs">@devonjhills</div>
              </div>
              <div class="text-neutral-400 group-hover:text-primary-500 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path>
                </svg>
              </div>
            </a>

            <!-- Resume -->
            <a
              href="/Devon_Hills_Resume_2025_Newest.pdf"
              target="_blank"
              class="flex items-center space-x-3 p-3 hover:bg-primary-50 dark:hover:bg-primary-950 border border-transparent hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-200 group cursor-pointer"
              style="border-radius: 0;"
            >
              <div
                class="w-8 h-8 bg-primary-100 dark:bg-primary-900 flex items-center justify-center text-primary-600 dark:text-primary-400 group-hover:bg-primary-200 dark:group-hover:bg-primary-800 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div class="flex-1">
                <div
                  class="text-neutral-900 dark:text-neutral-100 font-medium group-hover:text-primary-700 dark:group-hover:text-primary-300 transition-colors"
                >
                  resume.pdf
                </div>
                <div class="text-neutral-600 dark:text-neutral-400 text-xs">Download PDF</div>
              </div>
              <div class="text-neutral-400 group-hover:text-primary-500 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 10v6m0 0l-3-3m3 3l3-3"></path>
                </svg>
              </div>
            </a>
          </div>
        </div>

        <!-- Status Terminal -->
        <div
          class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 shadow-soft terminal-card"
          style="border-radius: 0;"
        >
          <!-- Terminal Header -->
          <div
            class="bg-neutral-100 dark:bg-neutral-800 px-4 py-3 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2"
          >
            <div class="flex space-x-1">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
            </div>
            <div class="flex-1">
              <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400"
                >~/status/current</span
              >
            </div>
          </div>
          <!-- Terminal Content -->
          <div class="p-6 font-terminal text-sm">
            <div class="text-primary-600 dark:text-primary-400 mb-4">$ cat status.txt</div>
            <div class="space-y-3 text-neutral-700 dark:text-neutral-300">
              <div class="flex items-center space-x-2">
                <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                <span class="text-green-600 dark:text-green-400">ONLINE</span>
              </div>
              <div class="mt-4 space-y-2">
                <div class="text-neutral-900 dark:text-neutral-100 font-medium">
                  Current Position:
                </div>
                <div class="text-sm">Software Engineer at Livefront</div>
                <div class="text-xs text-neutral-500 dark:text-neutral-400">
                  Building next-generation digital products
                </div>
              </div>
              <div class="mt-4 space-y-2">
                <div class="text-neutral-900 dark:text-neutral-100 font-medium">Availability:</div>
                <div class="text-sm">Open to interesting conversations</div>
                <div class="text-xs text-neutral-500 dark:text-neutral-400">
                  Technology, product development, collaboration
                </div>
              </div>
              <div class="mt-6 pt-4 border-t border-neutral-200 dark:border-neutral-700">
                <div class="text-xs text-neutral-500 dark:text-neutral-400">
                  Last updated: 09-09-2025
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Staggered animation for terminal cards */
  .grid > div:nth-child(1) {
    animation: fade-in-up 0.6s ease-out 0.1s both;
  }
  .grid > div:nth-child(2) {
    animation: fade-in-up 0.6s ease-out 0.3s both;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Terminal link hover effects */
  .terminal-card a:hover {
    background-color: rgba(34, 197, 94, 0.02);
  }

  .dark .terminal-card a:hover {
    background-color: rgba(34, 197, 94, 0.05);
  }
</style>
