---
// Contact section inspired by Livefront's partnership approach
---

<section id="contact" class="py-24 bg-white dark:bg-gray-950">
  <div class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 text-center">
    <!-- Main Contact Content -->
    <div class="space-y-12">
      <div class="space-y-6">
        <h2
          class="text-3xl sm:text-4xl lg:text-5xl font-heading font-semibold text-gray-900 dark:text-white leading-tight tracking-tight"
        >
          Let's build something remarkable.
        </h2>
        <p
          class="text-lg sm:text-xl text-gray-700 dark:text-gray-200 max-w-3xl mx-auto leading-relaxed"
        >
          I'm always interested in connecting with fellow developers, exploring new opportunities,
          and collaborating on projects that make a difference.
        </p>
      </div>

      <!-- Contact Options -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-16 max-w-2xl mx-auto">
        <!-- Email -->
        <a
          href="mailto:devonjhills@gmail.com"
          class="group bg-white dark:bg-gray-800 rounded-xl p-6 hover:bg-primary-50 dark:hover:bg-primary-950 transition-all duration-300 hover:scale-[1.02] shadow-soft hover:shadow-medium border border-gray-200 dark:border-gray-700 hover:border-primary-300 dark:hover:border-primary-700"
        >
          <div class="flex items-center space-x-4">
            <div
              class="w-12 h-12 bg-primary-100 dark:bg-primary-900 rounded-lg flex items-center justify-center group-hover:bg-primary-200 dark:group-hover:bg-primary-800 transition-colors duration-300"
            >
              <svg
                class="w-6 h-6 text-primary-600 dark:text-primary-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-900 dark:text-white text-sm">Email</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 truncate">devonjhills@gmail.com</p>
            </div>
          </div>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://linkedin.com/in/devonjhills"
          target="_blank"
          class="group bg-white dark:bg-gray-800 rounded-xl p-6 hover:bg-secondary-50 dark:hover:bg-secondary-950 transition-all duration-300 hover:scale-[1.02] shadow-soft hover:shadow-medium border border-gray-200 dark:border-gray-700 hover:border-secondary-300 dark:hover:border-secondary-700"
        >
          <div class="flex items-center space-x-4">
            <div
              class="w-12 h-12 bg-secondary-100 dark:bg-secondary-900 rounded-lg flex items-center justify-center group-hover:bg-secondary-200 dark:group-hover:bg-secondary-800 transition-colors duration-300"
            >
              <svg
                class="w-6 h-6 text-secondary-600 dark:text-secondary-400"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-900 dark:text-white text-sm">LinkedIn</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 truncate">Professional Network</p>
            </div>
          </div>
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com/devonjhills"
          target="_blank"
          class="group bg-white dark:bg-gray-800 rounded-xl p-6 hover:bg-accent-50 dark:hover:bg-accent-950 transition-all duration-300 hover:scale-[1.02] shadow-soft hover:shadow-medium border border-gray-200 dark:border-gray-700 hover:border-accent-300 dark:hover:border-accent-700"
        >
          <div class="flex items-center space-x-4">
            <div
              class="w-12 h-12 bg-accent-100 dark:bg-accent-900 rounded-lg flex items-center justify-center group-hover:bg-accent-200 dark:group-hover:bg-accent-800 transition-colors duration-300"
            >
              <svg
                class="w-6 h-6 text-accent-600 dark:text-accent-400"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-900 dark:text-white text-sm">GitHub</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 truncate">Code Portfolio</p>
            </div>
          </div>
        </a>

        <!-- Resume -->
        <a
          href="/Devon_Hills_Resume_2025_Newest.pdf"
          target="_blank"
          class="group bg-white dark:bg-gray-800 rounded-xl p-6 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-300 hover:scale-[1.02] shadow-soft hover:shadow-medium border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600"
        >
          <div class="flex items-center space-x-4">
            <div
              class="w-12 h-12 bg-gray-200 dark:bg-gray-700 rounded-lg flex items-center justify-center group-hover:bg-gray-300 dark:group-hover:bg-gray-600 transition-colors duration-300"
            >
              <svg
                class="w-6 h-6 text-gray-600 dark:text-gray-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                ></path>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-900 dark:text-white text-sm">Resume</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 truncate">Download PDF</p>
            </div>
          </div>
        </a>
      </div>

      <!-- Current Status -->
      <div class="mt-16 p-6 bg-primary-50 dark:bg-primary-950 rounded-xl">
        <p class="text-lg font-medium text-gray-900 dark:text-white mb-2">Currently at Livefront</p>
        <p class="text-gray-600 dark:text-gray-300">
          Building next-generation digital products and experiences for Fortune 500 companies.
          Always open to interesting conversations about technology, product development, and
          collaborative opportunities.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Staggered animation for contact cards */
  .grid > a:nth-child(1) {
    animation: fade-in-up 0.6s ease-out 0.1s both;
  }
  .grid > a:nth-child(2) {
    animation: fade-in-up 0.6s ease-out 0.2s both;
  }
  .grid > a:nth-child(3) {
    animation: fade-in-up 0.6s ease-out 0.3s both;
  }
  .grid > a:nth-child(4) {
    animation: fade-in-up 0.6s ease-out 0.4s both;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
