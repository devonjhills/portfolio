---
import Button from './ui/Button.astro';
import { Icon } from 'astro-icon/components';
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-gray-950/80 backdrop-blur-md border-b border-gray-200/50 dark:border-gray-800/50 shadow-subtle"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3 hover:opacity-80 transition-opacity">
        <img src="/logo2.png" alt="Devon Hills" class="w-8 h-8 rounded-lg" />
      </a>

      <!-- Navigation Menu (Desktop) -->
      <nav class="hidden md:flex items-center space-x-8">
        <a
          href="#services"
          class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
        >
          Services
        </a>
        <a
          href="#experience"
          class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
        >
          Experience
        </a>
        <a
          href="#projects"
          class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
        >
          Projects
        </a>
        <a
          href="#contact"
          class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
        >
          Contact
        </a>

        <!-- Theme Toggle -->
        <button
          id="theme-toggle"
          class="p-2 text-neutral-600 dark:text-neutral-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors rounded-lg"
          aria-label="Toggle theme"
        >
          <Icon name="heroicons:sun" class="hidden dark:block w-5 h-5" />
          <Icon name="heroicons:moon" class="block dark:hidden w-5 h-5" />
        </button>

        <!-- CTA Button -->
        <Button
          href="/Devon_Hills_Resume_2025_Newest.pdf"
          target="_blank"
          variant="primary"
          size="sm"
          download
        >
          Resume
          <Icon name="heroicons:arrow-down-tray" class="ml-2 w-4 h-4" />
        </Button>
      </nav>

      <!-- Mobile Menu Button and Theme Toggle Container -->
      <div class="md:hidden flex items-center space-x-2">
        <!-- Mobile Theme Toggle -->
        <button
          id="mobile-theme-toggle"
          class="p-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors rounded-lg"
          aria-label="Toggle theme"
        >
          <Icon name="heroicons:sun" class="hidden dark:block w-6 h-6" />
          <Icon name="heroicons:moon" class="block dark:hidden w-6 h-6" />
        </button>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-button"
          class="p-2 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          aria-label="Toggle navigation menu"
        >
          <Icon name="heroicons:bars-3" class="w-6 h-6" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-white dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800"
  >
    <div class="px-4 py-4 space-y-4">
      <a
        href="#services"
        class="block text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
      >
        Services
      </a>
      <a
        href="#experience"
        class="block text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
      >
        Experience
      </a>
      <a
        href="#projects"
        class="block text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
      >
        Projects
      </a>
      <a
        href="#contact"
        class="block text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
      >
        Contact
      </a>
      <Button
        href="/Devon_Hills_Resume_2025_Newest.pdf"
        target="_blank"
        variant="primary"
        size="md"
        download
        class="w-full justify-center"
      >
        Resume
        <Icon name="heroicons:arrow-down-tray" class="ml-2 w-4 h-4" />
      </Button>
    </div>
  </div>
</header>

<script>
  // Theme toggle functionality
  function initThemeToggle() {
    const themeToggle = document.getElementById('theme-toggle');
    const mobileThemeToggle = document.getElementById('mobile-theme-toggle');

    function toggleTheme() {
      const isDark = document.documentElement.classList.contains('dark');

      if (isDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    }

    if (themeToggle) {
      themeToggle.addEventListener('click', toggleTheme);
    }

    if (mobileThemeToggle) {
      mobileThemeToggle.addEventListener('click', toggleTheme);
    }
  }

  // Mobile menu toggle
  function initMobileMenu() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');

    if (button && menu) {
      button.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });

      // Close menu when clicking on links
      menu.addEventListener('click', e => {
        if ((e.target as HTMLElement)?.tagName === 'A') {
          menu.classList.add('hidden');
        }
      });

      // Close menu on outside click
      document.addEventListener('click', e => {
        if (!button.contains(e.target as Node) && !menu.contains(e.target as Node)) {
          menu.classList.add('hidden');
        }
      });
    }
  }

  // Initialize functions
  function initHeader() {
    initThemeToggle();
    initMobileMenu();
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initHeader);

  // Re-initialize for Astro page transitions
  document.addEventListener('astro:page-load', initHeader);
</script>
