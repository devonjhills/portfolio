---
// Services section inspired by Livefront's service offerings
---

<section id="services" class="py-24 bg-section-light-2 dark:bg-section-dark-2">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    <div class="text-center mb-20 animate-section-enter">
      <div
        class="inline-block mb-4 px-4 py-2 bg-neutral-100 dark:bg-neutral-900 border border-primary-500 dark:border-primary-400 font-terminal text-primary-700 dark:text-primary-300 relative shadow-sm"
        style="border-radius: 0;"
      >
        <span
          class="text-sm font-medium uppercase tracking-wide glitch-effect"
          data-text="$ ls ~/expertise">$ ls ~/expertise</span
        >
        <div class="absolute -top-2 -right-2 w-2 h-2 bg-primary-500 rounded-full animate-pulse">
        </div>
      </div>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-heading font-semibold text-neutral-900 dark:text-neutral-50 mb-6 leading-tight tracking-tight"
      >
        What I bring to your team
      </h2>
      <p
        class="text-lg sm:text-xl text-neutral-700 dark:text-neutral-300 max-w-3xl mx-auto leading-relaxed"
      >
        Full-stack expertise across modern technologies, with a focus on scalable architecture, user
        experience, and delivering products that make a real impact.
      </p>
    </div>

    <!-- Service Cards Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12 mb-20">
      <!-- Frontend Development -->
      <div
        class="bg-white dark:bg-neutral-900 p-0 shadow-soft hover:shadow-elevated border border-neutral-200 dark:border-primary-500/30 transition-all duration-300 hover:-translate-y-2 hover:scale-[1.02] group relative overflow-hidden terminal-card"
        style="border-radius: 0;"
      >
        <!-- Terminal Header Bar -->
        <div
          class="bg-neutral-100 dark:bg-neutral-800 px-4 py-2 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2"
        >
          <div class="flex space-x-1">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <div class="flex-1">
            <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400"
              >~/dev/frontend</span
            >
          </div>
        </div>
        <!-- Card Content -->
        <div class="p-8">
          <div class="flex items-start space-x-6">
            <div class="flex-shrink-0">
              <div
                class="w-14 h-14 bg-primary-100 dark:bg-primary-900 rounded-xl flex items-center justify-center shadow-soft group-hover:shadow-medium transition-all duration-300 group-hover:scale-105"
              >
                <svg
                  class="w-7 h-7 text-primary-600 dark:text-primary-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                </svg>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-heading font-medium text-gray-900 dark:text-white mb-3">
                Frontend Development
              </h3>
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Building modern, responsive interfaces with React, TypeScript, and Next.js. Focused
                on performance, accessibility, and exceptional user experiences.
              </p>
              <div class="flex flex-wrap gap-2">
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 text-sm font-terminal border border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900 transition-all duration-200"
                  style="border-radius: 0;">React</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 text-sm font-terminal border border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900 transition-all duration-200"
                  style="border-radius: 0;">TypeScript</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 text-sm font-terminal border border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900 transition-all duration-200"
                  style="border-radius: 0;">Next.js</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 text-sm font-terminal border border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900 transition-all duration-200"
                  style="border-radius: 0;">Tailwind.css</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Backend Development -->
      <div
        class="bg-white dark:bg-neutral-900 p-0 shadow-soft hover:shadow-elevated border border-neutral-200 dark:border-primary-500/30 transition-all duration-300 hover:-translate-y-2 hover:scale-[1.02] group relative overflow-hidden terminal-card"
        style="border-radius: 0;"
      >
        <!-- Terminal Header Bar -->
        <div
          class="bg-neutral-100 dark:bg-neutral-800 px-4 py-2 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2"
        >
          <div class="flex space-x-1">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <div class="flex-1">
            <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400"
              >~/dev/backend</span
            >
          </div>
        </div>
        <!-- Card Content -->
        <div class="p-8">
          <div class="flex items-start space-x-6">
            <div class="flex-shrink-0">
              <div
                class="w-14 h-14 bg-primary-100 dark:bg-primary-900 rounded-xl flex items-center justify-center shadow-soft group-hover:shadow-medium transition-all duration-300 group-hover:scale-105"
              >
                <svg
                  class="w-7 h-7 text-primary-600 dark:text-primary-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"
                  ></path>
                </svg>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-heading font-medium text-gray-900 dark:text-white mb-3">
                Backend Development
              </h3>
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Designing scalable APIs and data architectures. Experience with Ruby on Rails,
                Node.js, Python, and cloud platforms for high-traffic applications.
              </p>
              <div class="flex flex-wrap gap-2">
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 text-sm font-terminal border border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900 transition-all duration-200"
                  style="border-radius: 0;">rails</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 text-sm font-terminal border border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900 transition-all duration-200"
                  style="border-radius: 0;">node.js</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 text-sm font-terminal border border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900 transition-all duration-200"
                  style="border-radius: 0;">python</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 text-sm font-terminal border border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900 transition-all duration-200"
                  style="border-radius: 0;">postgresql</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-primary-700 dark:text-primary-300 text-sm font-terminal border border-primary-300 dark:border-primary-600 hover:bg-primary-100 dark:hover:bg-primary-900 transition-all duration-200"
                  style="border-radius: 0;">aws</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- System Architecture -->
      <div
        class="bg-white dark:bg-neutral-900 p-0 shadow-soft hover:shadow-elevated border border-neutral-200 dark:border-primary-500/30 transition-all duration-300 hover:-translate-y-2 hover:scale-[1.02] group relative overflow-hidden terminal-card"
        style="border-radius: 0;"
      >
        <!-- Terminal Header Bar -->
        <div
          class="bg-neutral-100 dark:bg-neutral-800 px-4 py-2 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2"
        >
          <div class="flex space-x-1">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <div class="flex-1">
            <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400"
              >~/dev/architecture</span
            >
          </div>
        </div>
        <!-- Card Content -->
        <div class="p-8">
          <div class="flex items-start space-x-6">
            <div class="flex-shrink-0">
              <div
                class="w-14 h-14 bg-neutral-100 dark:bg-neutral-900 rounded-xl flex items-center justify-center shadow-soft group-hover:shadow-medium transition-all duration-300 group-hover:scale-105"
              >
                <svg
                  class="w-7 h-7 text-neutral-600 dark:text-neutral-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                  ></path>
                </svg>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-heading font-medium text-gray-900 dark:text-white mb-3">
                System Architecture
              </h3>
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Designing resilient systems that scale. Experience with CI/CD pipelines, automated
                testing, and cloud infrastructure for healthcare and government applications.
              </p>
              <div class="flex flex-wrap gap-2">
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-sm font-terminal border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-all duration-200"
                  style="border-radius: 0;">jenkins</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-sm font-terminal border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-all duration-200"
                  style="border-radius: 0;">playwright</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-sm font-terminal border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-all duration-200"
                  style="border-radius: 0;">ci/cd</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-sm font-terminal border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-all duration-200"
                  style="border-radius: 0;">aws</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Product Strategy -->
      <div
        class="bg-white dark:bg-neutral-900 p-0 shadow-soft hover:shadow-elevated border border-neutral-200 dark:border-primary-500/30 transition-all duration-300 hover:-translate-y-2 hover:scale-[1.02] group relative overflow-hidden terminal-card"
        style="border-radius: 0;"
      >
        <!-- Terminal Header Bar -->
        <div
          class="bg-neutral-100 dark:bg-neutral-800 px-4 py-2 border-b border-neutral-200 dark:border-primary-500/30 flex items-center space-x-2"
        >
          <div class="flex space-x-1">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <div class="flex-1">
            <span class="font-terminal text-xs text-neutral-600 dark:text-neutral-400"
              >~/dev/strategy</span
            >
          </div>
        </div>
        <!-- Card Content -->
        <div class="p-8">
          <div class="flex items-start space-x-6">
            <div class="flex-shrink-0">
              <div
                class="w-14 h-14 bg-neutral-100 dark:bg-neutral-700 rounded-xl flex items-center justify-center shadow-soft group-hover:shadow-medium transition-all duration-300 group-hover:scale-105"
              >
                <svg
                  class="w-7 h-7 text-neutral-600 dark:text-neutral-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                  ></path>
                </svg>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-xl font-heading font-medium text-gray-900 dark:text-white mb-3">
                Product Strategy
              </h3>
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Collaborating with cross-functional teams including UX researchers, policy experts,
                and support staff to build accessible, user-centered healthcare applications.
              </p>
              <div class="flex flex-wrap gap-2">
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-sm font-terminal border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-all duration-200"
                  style="border-radius: 0;">agile</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-sm font-terminal border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-all duration-200"
                  style="border-radius: 0;">wcag</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-sm font-terminal border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-all duration-200"
                  style="border-radius: 0;">support</span
                >
                <span
                  class="px-3 py-1 bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-sm font-terminal border border-neutral-300 dark:border-neutral-600 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-all duration-200"
                  style="border-radius: 0;">healthcare</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Impact Statement -->
    <div class="text-center">
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-4xl mx-auto leading-relaxed">
        I bring technical excellence and product thinking together to build solutions that don't
        just work—they make a meaningful impact for users and businesses.
      </p>
    </div>
  </div>
</section>

<style>
  /* Staggered animation for service cards */
  .grid > div:nth-child(1) {
    animation: fade-in-up 0.6s ease-out 0.1s both;
  }
  .grid > div:nth-child(2) {
    animation: fade-in-up 0.6s ease-out 0.2s both;
  }
  .grid > div:nth-child(3) {
    animation: fade-in-up 0.6s ease-out 0.3s both;
  }
  .grid > div:nth-child(4) {
    animation: fade-in-up 0.6s ease-out 0.4s both;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
