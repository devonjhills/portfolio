---
import TerminalCard from './ui/TerminalCard.astro';
import { Icon } from 'astro-icon/components';
---

<section id="services" class="py-24 bg-section-light-2 dark:bg-section-dark-2">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    <div class="text-center mb-16 animate-section-enter">
      <div
        class="inline-block mb-3 px-3 py-1 bg-neutral-100 dark:bg-neutral-900 border border-neutral-300 dark:border-neutral-700 font-terminal relative shadow-sm"
        style="border-radius: 0;"
      >
        <span
          class="text-xs font-terminal tracking-normal text-neutral-600 dark:text-neutral-400 glitch-effect"
          data-text="$ find ~/dev -type d -name '*'">$ find ~/dev -type d -name '*'</span
        >
        <div class="absolute -top-2 -right-2 w-2 h-2 bg-primary-500 rounded-full animate-pulse">
        </div>
      </div>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-heading font-semibold text-neutral-900 dark:text-neutral-50 mb-6 leading-tight tracking-tight"
      >
        What I bring to your team
      </h2>
    </div>

    <!-- Service Cards Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12 mb-20">
      <!-- Frontend Development -->
      <TerminalCard
        title="Frontend Development"
        directory="~/dev/frontend"
        description="Building modern, responsive interfaces with React, TypeScript, and Next.js. Focused on performance, accessibility, and exceptional user experiences."
        tags={['React', 'TypeScript', 'Next.js', 'Tailwind.css']}
        tagType="primary"
      >
        <Icon
          name="heroicons:code-bracket"
          slot="icon"
          class="w-7 h-7 text-primary-600 dark:text-primary-400"
        />
      </TerminalCard>

      <!-- Backend Development -->
      <TerminalCard
        title="Backend Development"
        directory="~/dev/backend"
        description="Designing scalable APIs and data architectures. Experience with Ruby on Rails, Node.js, Python, and cloud platforms for high-traffic applications."
        tags={['rails', 'node.js', 'python', 'postgresql', 'aws']}
        tagType="primary"
      >
        <Icon
          name="heroicons:server"
          slot="icon"
          class="w-7 h-7 text-primary-600 dark:text-primary-400"
        />
      </TerminalCard>

      <!-- System Architecture -->
      <TerminalCard
        title="System Architecture"
        directory="~/dev/architecture"
        description="Designing resilient systems that scale. Experience with CI/CD pipelines, automated testing, and cloud infrastructure for healthcare and government applications."
        tags={['jenkins', 'playwright', 'ci/cd', 'aws']}
        tagType="neutral"
        iconBg="neutral"
      >
        <Icon
          name="heroicons:computer-desktop"
          slot="icon"
          class="w-7 h-7 text-neutral-600 dark:text-neutral-400"
        />
      </TerminalCard>

      <!-- Product Strategy -->
      <TerminalCard
        title="Product Strategy"
        directory="~/dev/strategy"
        description="Collaborating with cross-functional teams including UX researchers, policy experts, and support staff to build accessible, user-centered healthcare applications."
        tags={['agile', 'wcag', 'support', 'healthcare']}
        tagType="neutral"
        iconBg="neutral"
      >
        <Icon
          name="heroicons:light-bulb"
          slot="icon"
          class="w-7 h-7 text-neutral-600 dark:text-neutral-400"
        />
      </TerminalCard>
    </div>
  </div>
</section>

<style>
  /* Staggered animation for service cards */
  .grid > div:nth-child(1) {
    animation: fade-in-up 0.6s ease-out 0.1s both;
  }
  .grid > div:nth-child(2) {
    animation: fade-in-up 0.6s ease-out 0.2s both;
  }
  .grid > div:nth-child(3) {
    animation: fade-in-up 0.6s ease-out 0.3s both;
  }
  .grid > div:nth-child(4) {
    animation: fade-in-up 0.6s ease-out 0.4s both;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
