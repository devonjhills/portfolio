---
import '../styles/global.css';
import Header from '../components/Header.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Software Engineer specializing in React, TypeScript, and modern web development.',
  image = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Devon Hills" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content="Devon Hills - Software Engineer" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo2.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/logo2.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo2.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/logo2.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=Fira+Code:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Performance -->
    <meta name="generator" content={Astro.generator} />
  </head>
  <body
    class="font-sans antialiased bg-neutral-50 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100"
  >
    <!-- Code Rain Canvas -->
    <canvas id="code-rain" class="fixed inset-0 pointer-events-none z-0 opacity-25 dark:opacity-35"
    ></canvas>

    <Header />
    <slot />

    <!-- Theme Toggle Script -->
    <script>
      function initTheme() {
        const theme =
          localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }

      initTheme();

      document.addEventListener('astro:page-load', initTheme);
    </script>

    <!-- Code Rain Animation Script -->
    <script>
      let codeRainCanvas: HTMLCanvasElement | null,
        ctx: CanvasRenderingContext2D | null,
        drops: Array<{ y: number; speed: number; chars: string[] }> = [];
      const chars =
        'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲンｱｲｳｴｵｶｷｸｹｺｻｼｽｾｿﾀﾁﾂﾃﾄﾅﾆﾇﾈﾉﾊﾋﾌﾍﾎﾏﾐﾑﾒﾓﾔﾕﾖﾗﾘﾙﾚﾛﾜｦﾝ';

      function initCodeRain() {
        codeRainCanvas = document.getElementById('code-rain') as HTMLCanvasElement;
        if (!codeRainCanvas) return;

        ctx = codeRainCanvas.getContext('2d');
        resizeCanvas();

        // Create fewer, more spaced out drops for subtlety
        const columns = Math.floor(codeRainCanvas.width / 40);
        drops.length = 0;
        for (let i = 0; i < columns; i++) {
          drops[i] = {
            y: Math.random() * -800,
            speed: Math.random() * 0.6 + 0.2,
            chars: [],
          };

          // Generate random characters for this drop (longer chains)
          const length = Math.floor(Math.random() * 15) + 8;
          for (let j = 0; j < length; j++) {
            drops[i].chars.push(chars[Math.floor(Math.random() * chars.length)]);
          }
        }

        animate();
      }

      function resizeCanvas() {
        if (!codeRainCanvas) return;
        codeRainCanvas.width = window.innerWidth;
        codeRainCanvas.height = window.innerHeight;
      }

      function animate() {
        if (!ctx || !codeRainCanvas) return;

        // Clear background completely for sharp characters only
        ctx.clearRect(0, 0, codeRainCanvas.width, codeRainCanvas.height);

        // Check dark mode
        const isDark = document.documentElement.classList.contains('dark');

        for (let i = 0; i < drops.length; i++) {
          const drop = drops[i];
          const x = i * 40;

          // Draw characters
          for (let j = 0; j < drop.chars.length; j++) {
            const y = drop.y + j * 18;

            if (y > 0 && y < codeRainCanvas.height) {
              // Sharp gradient effect with full opacity at head
              const alpha = Math.max(0, (1 - j / drop.chars.length) * 1.0);

              if (isDark) {
                ctx.fillStyle = `rgba(0, 255, 65, ${alpha})`;
              } else {
                ctx.fillStyle = `rgba(34, 197, 94, ${alpha})`;
              }

              ctx.font = 'bold 14px "Fira Code", monospace';
              ctx.fillText(drop.chars[j], x, y);
            }
          }

          // Move drop slower
          drop.y += drop.speed;

          // Reset drop when it goes off screen
          if (drop.y > codeRainCanvas.height + 150) {
            drop.y = Math.random() * -800 - 300;
            drop.speed = Math.random() * 0.3 + 0.1;

            // Regenerate characters
            const length = Math.floor(Math.random() * 15) + 8;
            drop.chars.length = 0;
            for (let j = 0; j < length; j++) {
              drop.chars.push(chars[Math.floor(Math.random() * chars.length)]);
            }
          }
        }

        requestAnimationFrame(animate);
      }

      // Handle window resize
      window.addEventListener('resize', () => {
        resizeCanvas();
        // Adjust drops for new width without reinitializing
        if (codeRainCanvas) {
          const columns = Math.floor(codeRainCanvas.width / 40);
          if (columns !== drops.length) {
            // Preserve existing drops when possible
            const oldDrops = [...drops];
            drops.length = 0;

            for (let i = 0; i < columns; i++) {
              if (i < oldDrops.length) {
                // Keep existing drop but ensure it's within bounds
                drops[i] = oldDrops[i];
              } else {
                // Create new drop only if needed
                drops[i] = {
                  y: Math.random() * -800,
                  speed: Math.random() * 0.6 + 0.2,
                  chars: [],
                };

                // Generate random characters for new drop
                const length = Math.floor(Math.random() * 15) + 8;
                for (let j = 0; j < length; j++) {
                  drops[i].chars.push(chars[Math.floor(Math.random() * chars.length)]);
                }
              }
            }
          }
        }
      });

      // Initialize
      document.addEventListener('DOMContentLoaded', initCodeRain);
      document.addEventListener('astro:page-load', initCodeRain);

      // Pause animation when page is not visible (performance optimization)
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          // Animation will pause naturally since requestAnimationFrame stops
        } else {
          // Resume animation if needed
          if (codeRainCanvas && ctx) {
            animate();
          }
        }
      });
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: 'Inter', system-ui, sans-serif;
  }

  body {
    margin: 0;
    min-height: 100vh;
    /* Subtle texture overlay */
    position: relative;
  }

  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      radial-gradient(circle at 15% 85%, rgba(34, 197, 94, 0.06) 0%, transparent 60%),
      radial-gradient(circle at 85% 15%, rgba(22, 163, 74, 0.04) 0%, transparent 55%),
      radial-gradient(circle at 45% 45%, rgba(21, 128, 61, 0.03) 0%, transparent 50%),
      radial-gradient(circle at 70% 30%, rgba(16, 185, 129, 0.025) 0%, transparent 45%);
    pointer-events: none;
    z-index: -1;
    opacity: 0.7;
  }

  .dark body::before {
    background-image:
      radial-gradient(circle at 15% 85%, rgba(0, 255, 65, 0.08) 0%, transparent 70%),
      radial-gradient(circle at 85% 15%, rgba(0, 220, 50, 0.06) 0%, transparent 65%),
      radial-gradient(circle at 45% 45%, rgba(0, 190, 40, 0.04) 0%, transparent 60%),
      radial-gradient(circle at 70% 30%, rgba(0, 255, 80, 0.03) 0%, transparent 55%),
      linear-gradient(180deg, rgba(0, 0, 0, 0.95) 0%, rgba(0, 0, 0, 0.98) 100%);
    opacity: 0.9;
  }

  /* Smooth scrolling for all elements */
  * {
    scroll-behavior: smooth;
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: theme('colors.neutral.200');
  }

  ::-webkit-scrollbar-thumb {
    background: theme('colors.primary.500');
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: theme('colors.primary.600');
  }

  .dark ::-webkit-scrollbar-track {
    background: theme('colors.neutral.800');
  }

  .dark ::-webkit-scrollbar-thumb {
    background: theme('colors.primary.400');
  }

  .dark ::-webkit-scrollbar-thumb:hover {
    background: theme('colors.primary.300');
  }

  /* Terminal Aesthetics */
  .terminal-card {
    position: relative;
    background: linear-gradient(135deg, rgba(255, 255, 255, 1) 0%, rgba(250, 250, 250, 1) 100%);
  }

  .dark .terminal-card {
    background: linear-gradient(135deg, rgba(10, 10, 10, 1) 0%, rgba(0, 0, 0, 1) 100%);
  }

  .terminal-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(34, 197, 94, 0.5), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .terminal-card:hover::before {
    opacity: 1;
  }

  .font-terminal {
    font-family:
      'Fira Code', 'SF Mono', 'Monaco', 'Consolas', 'Liberation Mono', 'Courier New', monospace;
    font-feature-settings:
      'liga' 1,
      'calt' 1;
    font-weight: 400;
  }

  /* Matrix-style glitch effects */
  .glitch-effect {
    position: relative;
    color: inherit;
    transition: all 0.3s ease;
  }

  .glitch-effect:hover {
    animation: glitch 0.5s linear infinite;
  }

  .glitch-effect:hover::before {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 2px;
    width: 100%;
    color: rgba(255, 0, 0, 0.8);
    background: transparent;
    overflow: hidden;
    clip: rect(0, 900px, 0, 0);
    animation: glitch-shadow-1 0.5s linear infinite;
  }

  .glitch-effect:hover::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: -2px;
    width: 100%;
    color: rgba(0, 255, 255, 0.8);
    background: transparent;
    overflow: hidden;
    clip: rect(0, 900px, 0, 0);
    animation: glitch-shadow-2 0.5s linear infinite;
  }

  @keyframes glitch {
    2%,
    64% {
      transform: translate(2px, 0) skew(0deg);
    }
    4%,
    60% {
      transform: translate(-2px, 0) skew(0deg);
    }
    62% {
      transform: translate(0, 0) skew(5deg);
    }
  }

  @keyframes glitch-shadow-1 {
    2%,
    64% {
      transform: translate(2px, 0) skew(0deg);
      clip: rect(0, 900px, 0, 0);
    }
    4%,
    60% {
      transform: translate(-2px, 0) skew(0deg);
      clip: rect(0, 900px, 0, 0);
    }
    62% {
      transform: translate(13px, 0) skew(-13deg);
      clip: rect(0, 900px, 0, 0);
    }
  }

  @keyframes glitch-shadow-2 {
    2%,
    64% {
      transform: translate(-2px, 0) skew(0deg);
      clip: rect(0, 900px, 0, 0);
    }
    4%,
    60% {
      transform: translate(2px, 0) skew(0deg);
      clip: rect(0, 900px, 0, 0);
    }
    62% {
      transform: translate(-13px, 0) skew(13deg);
      clip: rect(0, 900px, 0, 0);
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .glitch-effect:hover {
      animation: none;
    }
    .glitch-effect:hover::before,
    .glitch-effect:hover::after {
      animation: none;
    }
  }
</style>
